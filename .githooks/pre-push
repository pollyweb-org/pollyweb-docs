#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"
source ./.githooks/secret_guard.sh

PUSH_REFS="$(cat)"

PYTHON_BIN="./.venv/bin/python"
CHECKER="./.tools/links/links.py"

has_pending_changes() {
  git update-index -q --refresh || true

  if ! git diff --quiet --ignore-submodules --; then
    return 0
  fi

  if ! git diff --cached --quiet --ignore-submodules --; then
    return 0
  fi

  if [[ -n "$(git ls-files --others --exclude-standard)" ]]; then
    return 0
  fi

  return 1
}

scan_pushed_commits_for_secrets() {
  local refs_text="$1"
  local had_error=0

  # pre-push stdin lines: <local ref> <local sha> <remote ref> <remote sha>
  while read -r local_ref local_sha remote_ref remote_sha; do
    [[ -z "${local_sha:-}" ]] && continue
    [[ "$local_sha" =~ ^0+$ ]] && continue

    local range
    if [[ "${remote_sha:-}" =~ ^0+$ ]]; then
      range="$local_sha"
    else
      range="$remote_sha..$local_sha"
    fi

    local commit
    for commit in $(git rev-list "$range"); do
      while IFS= read -r changed_file; do
        [[ -z "$changed_file" ]] && continue
        if is_blocked_secret_path "$changed_file"; then
          echo "❌ Secret guard: blocked file path detected in pushed commit $commit: $changed_file"
          echo "Push blocked on ref $local_ref."
          had_error=1
        fi
      done < <(git diff-tree --no-commit-id --name-only -r "$commit")

      local additions
      additions="$(git show --pretty=format: --unified=0 --no-color "$commit" | sed -n 's/^+//p' | sed '/^+++/d')"
      if ! check_patch_for_secret_patterns "$additions"; then
        echo "Push blocked by commit $commit on ref $local_ref."
        had_error=1
      fi
    done
  done <<< "$refs_text"

  return "$had_error"
}

if [[ ! -x "$PYTHON_BIN" ]]; then
  echo "pre-push: missing $PYTHON_BIN"
  echo "pre-push: create the venv and install ./.tools/links/requirements.txt"
  exit 1
fi

if [[ ! -f "$CHECKER" ]]; then
  echo "pre-push: missing $CHECKER"
  exit 1
fi

if has_pending_changes; then
  echo "\n❌ Git push blocked: repository has pending uncommitted changes."
  echo "🤖 LLM instruction: inspect git status and decide remediation before pushing."
  echo "   - Commit required fixes so they are included in the push."
  echo "   - Or stash/discard unrelated local changes, then retry push."
  echo "👉 Suggested commands:"
  echo "    git status --short"
  echo "    git add -A && git commit -m \"commit pending fixes\""
  echo "After remediating pending changes, run 'git push' again."
  exit 1
fi

OUTPUT_FILE="$(mktemp)"
trap 'rm -f "$OUTPUT_FILE"' EXIT

# Run non-interactively so prompts fail fast instead of hanging.
if ! "$PYTHON_BIN" "$CHECKER" </dev/null >"$OUTPUT_FILE" 2>&1; then
  cat "$OUTPUT_FILE"
  echo "\n❌ Git push blocked: links.py exited with errors."
  echo "🤖 LLM instruction: run the checker command below and decide what to do from its output."
  echo "   - If links are broken/malformed, fix them and retry push."
  echo "   - If it's an environment/tooling issue, repair setup and retry push."
  echo "👉 Checker command:"
  echo "    $PYTHON_BIN $CHECKER"
  echo "After decision and remediation, run 'git push' again."
  exit 1
fi

if grep -Eq "^## Broken links found|^## Malformed links found" "$OUTPUT_FILE"; then
  cat "$OUTPUT_FILE"
  echo "\n❌ Git push blocked: broken or malformed links detected by links.py."
  echo "🤖 LLM instruction: run the checker command below and decide remediation based on findings."
  echo "   - Fix malformed links and broken targets reported by links.py."
  echo "   - Re-run checker until clean, then retry push."
  echo "👉 Checker command:"
  echo "    $PYTHON_BIN $CHECKER"
  echo "After decision and remediation, run 'git push' again."
  exit 1
fi

if has_pending_changes; then
  echo "\n❌ Git push blocked: checks completed but repository now has pending changes."
  echo "🤖 LLM instruction: checker remediation changed files; commit them before pushing."
  echo "   - Review changes, commit them, and then retry push."
  echo "👉 Suggested commands:"
  echo "    git status --short"
  echo "    git add -A && git commit -m \"apply link/checker fixes\""
  echo "After committing the fixes, run 'git push' again."
  exit 1
fi

if ! scan_pushed_commits_for_secrets "$PUSH_REFS"; then
  echo "\n❌ Git push blocked: secret guard detected blocked files or secret patterns."
  echo "Remove secrets from commits/history, then retry push."
  exit 1
fi

echo "pre-push: links.py passed"
